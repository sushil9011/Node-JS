<%- include('../header') %>

    <div class="form-wrapper" style="padding: 40px; background: #edeff2; min-height: 90vh;">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="glass-card"
                        style="background: white; border-radius: 35px; padding: 40px; border: none;">
                        <h4 class="fw-bold mb-4 border-bottom pb-3">Edit Extra Category</h4>

                        <form action="/extracategory/updateExtraCategory" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="id" value="<%= singleData._id %>">

                            <div class="mb-3">
                                <label class="form-label"
                                    style="font-weight: 700; font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 8px;">Category</label>
                                <select name="categoryId" class="form-select"
                                    style="border-radius: 15px; padding: 12px 20px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;">
                                    <% categories.forEach((cat)=> { %>
                                        <option value="<%= cat._id %>"
                                            <%=cat._id.toString()===singleData.categoryId.toString() ? 'selected' : ''
                                            %>><%= cat.category_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label"
                                    style="font-weight: 700; font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 8px;">Sub-Category</label>
                                <select name="subcategoryId" class="form-select"
                                    style="border-radius: 15px; padding: 12px 20px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;">
                                    <% subcategories.forEach((sub)=> { %>
                                        <option value="<%= sub._id %>"
                                            <%=sub._id.toString()===singleData.subcategoryId.toString() ? 'selected'
                                            : '' %>><%= sub.subcategory_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label"
                                    style="font-weight: 700; font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 8px;">Extra
                                    Category Name</label>
                                <input type="text" name="extracategoryname" value="<%= singleData.extracategoryname %>"
                                    class="form-control"
                                    style="border-radius: 15px; padding: 12px 20px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;"
                                    required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label"
                                    style="font-weight: 700; font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 8px;">Current
                                    Image</label>
                                <div class="mb-2">
                                    <img src="/<%= singleData.extracategory_image %>"
                                        style="width: 80px; border-radius: 12px; border: 1px solid #eee;">
                                </div>
                                <input type="file" name="extracategory_image" class="form-control"
                                    style="border-radius: 15px; padding: 12px 20px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;">
                            </div>

                            <button type="submit" class="btn-save"
                                style="background: #1a1b1e; color: white; border-radius: 18px; padding: 15px; width: 100%; border: none; font-weight: 700;">Update
                                Changes</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>