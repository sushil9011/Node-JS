<%- include('../header') %>

    <style>
        .form-wrapper {
            padding: 40px;
            background: #edeff2;
            min-height: 90vh;
        }

        .glass-card {
            background: white;
            border-radius: 35px;
            padding: 40px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .form-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
        }

        .form-control,
        .form-select {
            border-radius: 15px;
            padding: 12px 20px;
            border: 1px solid #f1f5f9;
            background: #f8fafc;
            transition: 0.3s;
        }

        .form-control:focus {
            background: white;
            border-color: #000;
            box-shadow: none;
        }

        .btn-save {
            background: #1a1b1e;
            color: white;
            border-radius: 18px;
            padding: 15px;
            width: 100%;
            border: none;
            font-weight: 700;
            margin-top: 20px;
        }
    </style>

    <div class="form-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="glass-card">
                        <h4 class="fw-bold mb-4 border-bottom pb-3">Add Extra Category</h4>
                        <form action="/extracategory/insertExtraCategory" method="POST" enctype="multipart/form-data">

                            <div class="mb-3">
                                <label class="form-label">Select Category</label>
                                <select name="categoryId" class="form-select" required>
                                    <option value="" disabled selected>-- Choose Category --</option>
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat._id %>">
                                            <%= cat.category_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Select Sub-Category</label>
                                <select name="subcategoryId" class="form-select" required>
                                    <option value="" disabled selected>-- Choose Sub-Category --</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Extra Category Name</label>
                                <input type="text" name="extracategoryname" class="form-control"
                                    placeholder="Enter name" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Upload Image</label>
                                <input type="file" name="extracategory_image" class="form-control" required>
                            </div>

                            <button type="submit" class="btn-save shadow">Save Category</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Original AJAX Script for Subcategories
        document.querySelector('select[name="categoryId"]').addEventListener('change', async function () {
            const catId = this.value;
            const subSelect = document.querySelector('select[name="subcategoryId"]');
            subSelect.innerHTML = '<option value="" disabled selected>Loading...</option>';

            try {
                const response = await fetch(`/extracategory/getSubcategories/${catId}`);
                const data = await response.json();
                let options = '<option value="" disabled selected>-- Choose Sub-Category --</option>';
                data.forEach(sub => {
                    options += `<option value="${sub._id}">${sub.subcategory_name}</option>`;
                });
                subSelect.innerHTML = options;
            } catch (error) {
                subSelect.innerHTML = '<option value="" disabled selected>Error loading</option>';
            }
        });
    </script>
    <%- include('../footer') %>