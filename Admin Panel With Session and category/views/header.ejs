<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sushil Admin | Premium Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --sidebar-width: 280px;
            --bg-outer: #edeff2;
            --glass-white: rgba(255, 255, 255, 0.8);
            --active-dark: #1a1b1e;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-outer);
            margin: 0;
            color: #1a1b1e;
        }

        /* Modern Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            height: 95vh;
            background: white;
            color: #1a1b1e;
            position: fixed;
            left: 20px;
            top: 2.5vh;
            border-radius: 35px;
            transition: 0.3s;
            z-index: 1050;
            overflow-y: auto;
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        }

        .sidebar-brand {
            padding: 40px 30px;
            font-weight: 800;
            letter-spacing: -1px;
            font-size: 1.5rem;
            color: #000;
        }

        /* Sidebar Nav Links */
        .nav-link {
            color: #64748b !important;
            padding: 14px 25px;
            border-radius: 20px !important;
            margin: 4px 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .nav-link i:first-child {
            width: 25px;
            font-size: 1.1rem;
            margin-right: 12px;
        }

        .nav-link:hover {
            background: #f8fafc !important;
            color: #000 !important;
            transform: translateX(5px);
        }

        .nav-link.active {
            background: var(--active-dark) !important;
            color: white !important;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        /* Dropdown Sub-menu */
        .collapse-inner {
            background: #f8fafc;
            margin: 5px 20px;
            border-radius: 20px;
            padding: 10px 0;
        }

        .sub-nav-link {
            padding: 10px 25px 10px 55px;
            color: #64748b;
            text-decoration: none;
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            transition: 0.2s;
        }

        .sub-nav-link:hover {
            color: #000;
        }

        /* Main Wrapper & Navbar */
        .main-wrapper {
            margin-left: calc(var(--sidebar-width) + 40px);
            padding: 20px 20px 20px 0;
            transition: 0.3s;
        }

        .navbar-custom {
            background: transparent;
            padding: 20px 10px;
            margin-bottom: 20px;
        }

        .profile-btn {
            background: white;
            padding: 8px 15px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            border: none;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02);
        }

        .profile-pic {
            width: 40px;
            height: 40px;
            border-radius: 15px;
            object-fit: cover;
            margin-left: 10px;
        }

        /* Remove default toggle arrow */
        .dropdown-toggle::after {
            display: none;
        }

        @media (max-width: 992px) {
            .sidebar {
                left: -300px;
            }

            .main-wrapper {
                margin-left: 0;
                padding: 20px;
            }

            .sidebar.show {
                left: 20px;
            }
        }
    </style>
</head>

<body>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            iDraft Admin
        </div>

        <ul class="nav flex-column">
            <li class="nav-item">
                <a href="/dashboard" class="nav-link" id="nav-dashboard">
                    <i class="bi bi-grid-fill"></i> Dashboard
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link justify-content-between" data-bs-toggle="collapse" href="#adminMenu">
                    <span><i class="bi bi-person-badge-fill"></i> Admins</span>
                    <i class="fa fa-chevron-down small opacity-50"></i>
                </a>
                <div class="collapse" id="adminMenu">
                    <div class="collapse-inner">
                        <a href="/admin/addAdminPage" class="sub-nav-link">Add New Entry</a>
                        <a href="/admin/viewAdminPage" class="sub-nav-link">Manage Admins</a>
                    </div>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link justify-content-between" data-bs-toggle="collapse" href="#catMenu">
                    <span><i class="bi bi-folder-fill"></i> Category</span>
                    <i class="fa fa-chevron-down small opacity-50"></i>
                </a>
                <div class="collapse" id="catMenu">
                    <div class="collapse-inner">
                        <a href="/category/addCategory" class="sub-nav-link">Add Category</a>
                        <a href="/category/viewCategory" class="sub-nav-link">View Category</a>
                    </div>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link justify-content-between" data-bs-toggle="collapse" href="#subCatMenu">
                    <span><i class="bi bi-layers-fill"></i> Sub-Category</span>
                    <i class="fa fa-chevron-down small opacity-50"></i>
                </a>
                <div class="collapse" id="subCatMenu">
                    <div class="collapse-inner">
                        <a href="/subcategory/addSubCategory" class="sub-nav-link">Add Sub-Category</a>
                        <a href="/subcategory/viewSubCategory" class="sub-nav-link">View Sub-Category</a>
                    </div>
                </div>
            </li>
            <li class="nav-item">
                <a class="nav-link justify-content-between" data-bs-toggle="collapse" href="#extraCategoryMenu">
                    <span><i class="bi bi-layers-fill"></i> Extra-Category</span>
                    <i class="fa fa-chevron-down small opacity-50"></i>
                </a>
                <div class="collapse" id="extraCategoryMenu">
                    <div class="collapse-inner">
                        <a href="/extracategory/addExtraCategory" class="sub-nav-link">Add Sub-Category</a>
                        <a href="/extracategory/viewExtraCategory" class="sub-nav-link">View Sub-Category</a>
                    </div>
                </div>
            </li>


            <li class="nav-item">
                <a href="#prodMenu" class="nav-link justify-content-between" data-bs-toggle="collapse">
                    <span><i class="bi bi-box-seam-fill"></i> Products</span>
                    <i class="fa fa-chevron-down small opacity-50"></i>
                </a>
                <div class="collapse" id="prodMenu">
                    <div class="collapse-inner">
                        <a href="/product/addProduct" class="sub-nav-link">Add Product</a>
                        <a href="/product/viewProduct" class="sub-nav-link">View Product</a>
                    </div>
                </div>
            </li>
        </ul>
    </div>

    <div class="main-wrapper">
        <nav class="navbar navbar-custom">
            <div class="container-fluid">
                <button class="btn d-lg-none" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="fa fa-bars"></i>
                </button>

                <div class="ms-auto d-flex align-items-center">
                    <div class="dropdown">
                        <button class="profile-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <div class="text-end d-none d-sm-block me-2">
                                <p class="mb-0 fw-bold small">
                                    <%= admin.fname %>
                                        <%= admin.lname %>
                                </p>
                                <p class="mb-0 text-muted extra-small" style="font-size: 10px;">
                                    <%= admin.email %>
                                </p>
                            </div>
                            <img src="/<%= admin.profile_image %>" class="profile-pic">
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2" style="border-radius: 20px;">
                            <li><a class="dropdown-item rounded-3" href="/profile"><i class="bi bi-person me-2"></i>
                                    Profile</a></li>
                            <li><a class="dropdown-item rounded-3" href="/admin/change-password-page"><i
                                        class="bi bi-shield-lock me-2"></i> Security</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item rounded-3 text-danger" href="/logout"><i
                                        class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <div class="content-body">


           