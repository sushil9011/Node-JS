<%- include('header') %>

    <style>
        /* iDraft Premium Design Theme */
        :root {
            --glass-bg: rgba(255, 255, 255, 0.6);
            --dark-accent: #1a1b1e;
            --soft-border: rgba(255, 255, 255, 0.3);
            --shadow-sm: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        }

        .page-content {
            background: #edeff2;
            /* Outer background from image */
            padding: 40px;
            min-height: 100vh;
        }

        .dashboard-wrapper {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            border-radius: 40px;
            border: 1px solid var(--soft-border);
            padding: 40px;
            box-shadow: var(--shadow-sm);
        }

        /* Top Stats Card (Dark Theme) */
        .overall-stats-card {
            background: var(--dark-accent);
            border-radius: 30px;
            padding: 30px;
            color: white;
            height: 100%;
        }

        .mini-stat-item {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 15px;
            text-align: center;
            transition: 0.3s;
        }

        .mini-stat-item:hover {
            background: white;
            color: black;
        }

        /* Activity Cards (White Theme) */
        .activity-card {
            background: white;
            border-radius: 30px;
            padding: 25px;
            border: none;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.02);
            height: 100%;
        }

        .icon-circle-custom {
            width: 45px;
            height: 45px;
            background: #f4f7fa;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }

        .fw-black {
            font-weight: 900;
        }
    </style>

    <div class="page-content">
        <div class="dashboard-wrapper">
            <div class="row g-4">

                <div class="col-lg-4 col-12">
                    <div class="mb-4">
                        <h2 class="fw-black">Hi, <%= admin.name %>!</h2>
                        <p class="text-muted">Welcome to your store overview</p>
                    </div>

                    <div class="overall-stats-card">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="small opacity-75">OVERALL INFORMATION</span>
                            <i class="fas fa-ellipsis-h"></i>
                        </div>

                        <div class="row g-2">
                            <div class="col-4">
                                <div class="mini-stat-item">
                                    <h4 class="fw-black mb-0">
                                        <%= totalCat %>
                                    </h4>
                                    <small class="opacity-50">Cat</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="mini-stat-item">
                                    <h4 class="fw-black mb-0">
                                        <%= totalSub %>
                                    </h4>
                                    <small class="opacity-50">Sub</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="mini-stat-item">
                                    <h4 class="fw-black mb-0">
                                        <%= totalProduct %>
                                    </h4>
                                    <small class="opacity-50">Prod</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 col-12">
                    <div class="activity-card">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h6 class="fw-bold m-0">Weekly progress</h6>
                            <div class="icon-circle-custom"><i class="fas fa-chart-line text-primary"></i></div>
                        </div>
                        <div class="p-4 bg-light rounded-4 text-center mb-3">
                            <p class="small text-muted mb-1">Performance Rate</p>
                            <h2 class="fw-black">+24.8%</h2>
                        </div>
                        <div class="d-flex justify-content-between text-muted small">
                            <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 col-12">
                    <div class="activity-card text-center">
                        <h6 class="fw-bold mb-4">Month progress</h6>
                        <div
                            style="width: 130px; height: 130px; border: 12px solid #f1f5f9; border-top-color: #000; border-radius: 50%; margin: 0 auto; display: flex; align-items: center; justify-content: center;">
                            <h3 class="fw-black mb-0">92%</h3>
                        </div>
                        <p class="small text-muted mt-3">Overall inventory health</p>
                        <button class="btn btn-dark w-100 rounded-pill py-3 mt-2">Generate Report</button>
                    </div>
                </div>

                <div class="col-lg-5 col-12">
                    <div class="activity-card" style="background: #eef2ff; border: 1px solid #e0e7ff;">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-circle-custom bg-white mb-0 me-3"><i class="fas fa-tags text-indigo"></i>
                            </div>
                            <h6 class="fw-bold m-0">Extra-Category Meta</h6>
                        </div>
                        <h3 class="fw-black">
                            <%= totalExtra %> <span class="fs-6 fw-normal text-muted">Active Tiers</span>
                        </h3>
                    </div>
                </div>

                <div class="col-lg-7 col-12">
                    <div class="activity-card bg-dark text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold m-0">System Security</h5>
                            <span class="badge rounded-pill bg-success px-3">Encrypted</span>
                        </div>
                        <p class="mt-3 opacity-50 small">All database connections for products and categories are
                            currently secure and optimized.</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <%- include('footer') %>