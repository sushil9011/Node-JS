<%- include('../header') %>

    <style>
        .form-wrapper {
            padding: 40px;
            background: #edeff2;
            min-height: 90vh;
        }

        .iDraft-card {
            background: white;
            border-radius: 35px;
            padding: 40px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .form-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 10px;
        }

        .form-control,
        .form-select {
            border-radius: 15px;
            padding: 12px 20px;
            border: 1px solid #f1f5f9;
            background: #f8fafc;
            transition: 0.3s;
        }

        .form-control:focus {
            background: white;
            border-color: #000;
            box-shadow: none;
            outline: none;
        }

        .btn-save {
            background: #1a1b1e;
            color: white;
            border-radius: 18px;
            padding: 15px;
            width: 100%;
            border: none;
            font-weight: 700;
            margin-top: 20px;
        }
    </style>

    <div class="form-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-7">
                    <div class="iDraft-card">
                        <h4 class="fw-bold mb-4">Add Sub-Category</h4>

                        <form action="/subcategory/insertSubCategory" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label">Parent Category</label>
                                <select name="categoryId" class="form-select" required>
                                    <option value="" selected disabled>-- Select Main Category --</option>
                                    <% categories.forEach((cat)=> { %>
                                        <option value="<%= cat._id %>">
                                            <%= cat.category_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Sub-Category Name</label>
                                <input type="text" name="subcategory_name" class="form-control"
                                    placeholder="e.g. Smart Watches" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Sub-Category Image</label>
                                <input type="file" name="subcategory_image" class="form-control" required>
                            </div>

                            <button type="submit" class="btn-save shadow">Save Sub-Category</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>