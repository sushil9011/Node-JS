<%- include('../header') %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg" style="border-radius: 25px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="bg-light d-inline-block p-3 rounded-circle mb-3">
                                <i class="fas fa-lock-open fa-2x text-dark"></i>
                            </div>
                            <h4 class="font-weight-bold">Security Update</h4>
                            <p class="text-muted small">Update your account password</p>
                        </div>

                        <form method="post" action="/admin/change-password">
                            <div class="form-group mb-3">
                                <label class="small font-weight-bold text-muted">Current Password</label>
                                <input type="password" class="form-control" name="current_psw" required>
                            </div>
                            <hr class="my-4">
                            <div class="form-group mb-3">
                                <label class="small font-weight-bold text-primary">New Password</label>
                                <input type="password" class="form-control border-primary" name="new_psw" required>
                            </div>
                            <div class="form-group mb-4">
                                <label class="small font-weight-bold text-primary">Confirm New Password</label>
                                <input type="password" class="form-control border-primary" name="conform_psw" required>
                            </div>
                            <button type="submit" class="btn btn-dark btn-block py-3 fw-bold rounded-pill">Update
                                Securely</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../footer') %>