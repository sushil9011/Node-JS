
<%- include('../header') %>

    <style>
        .form-page-wrapper {
            padding: 40px;
            background: #edeff2;
            min-height: 90vh;
        }

        .iDraft-form-card {
            background: white;
            border-radius: 35px;
            border: none;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .field-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
            display: block;
        }

        .custom-input {
            border-radius: 15px;
            padding: 12px 20px;
            border: 1px solid #f1f5f9;
            background: #f8fafc;
            transition: 0.3s;
            width: 100%;
        }

        .custom-input:focus {
            background: white;
            border-color: #000;
            outline: none;
        }

        .btn-create-admin {
            background: #1a1b1e;
            color: white;
            border-radius: 18px;
            padding: 15px;
            width: 100%;
            border: none;
            font-weight: 700;
            margin-top: 25px;
            transition: 0.3s;
        }

        .btn-create-admin:hover {
            background: #000;
            transform: translateY(-2px);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 800;
            margin-bottom: 25px;
            color: #1e293b;
        }
    </style>

    <div class="form-page-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="iDraft-form-card">
                        <div class="section-title">Register New Admin</div>

                        <form action="/admin/insertAdmin" method="post" enctype="multipart/form-data">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="field-label">First Name</label>
                                    <input type="text" name="fname" class="custom-input" placeholder="Enter first name"
                                        required>
                                </div>
                                <div class="col-md-6">
                                    <label class="field-label">Last Name</label>
                                    <input type="text" name="lname" class="custom-input" placeholder="Enter last name"
                                        required>
                                </div>

                                <div class="col-12">
                                    <label class="field-label">Email Address</label>
                                    <input type="email" name="email" class="custom-input"
                                        placeholder="admin@example.com" required>
                                </div>

                                <div class="col-md-6">
                                    <label class="field-label">City</label>
                                    <select name="city" class="custom-input">
                                        <option value="">--Select City--</option>
                                        <option value="surat">Surat</option>
                                        <option value="vapi">Vapi</option>
                                        <option value="valsad">Valsad</option>
                                        <option value="rajkot">Rajkot</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="field-label">Gender</label>
                                    <div class="pt-2">
                                        <input type="radio" name="gender" value="male"> Male &nbsp;&nbsp;
                                        <input type="radio" name="gender" value="female"> Female
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="field-label">Hobbies</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        <label><input type="checkbox" name="hobby" value="reading"> Reading</label>
                                        <label><input type="checkbox" name="hobby" value="coding"> Coding</label>
                                        <label><input type="checkbox" name="hobby" value="music"> Music</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="field-label">Profile Picture</label>
                                    <input type="file" name="profile_image" class="custom-input" required>
                                </div>

                                <div class="col-12">
                                    <label class="field-label">About Information</label>
                                    <textarea name="about" class="custom-input" rows="3"
                                        placeholder="Short bio..."></textarea>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn-create-admin shadow-sm">Add New
                                        Administrator</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>