
<%- include('../header') %>

    <style>
        .edit-page-container {
            padding: 40px;
            background: #edeff2;
            min-height: 90vh;
        }

        .iDraft-card {
            background: white;
            border-radius: 35px;
            padding: 40px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .form-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 15px;
            padding: 12px 20px;
            border: 1px solid #f1f5f9;
            background: #f8fafc;
            transition: 0.3s;
        }

        .form-control:focus {
            background: white;
            border-color: #000;
            box-shadow: none;
        }

        .btn-update-now {
            background: #1a1b1e;
            color: white;
            border-radius: 18px;
            padding: 15px;
            width: 100%;
            border: none;
            font-weight: 700;
            margin-top: 20px;
        }

        .current-img-box {
            width: 80px;
            height: 80px;
            border-radius: 15px;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
    </style>

    <div class="edit-page-container">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="iDraft-card">
                        <h4 class="fw-bold mb-4">Edit Profile</h4>

                        <form action="/admin/editAdmin/<%= singleAdmin.id %>" method="post"
                            enctype="multipart/form-data">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <input type="text" name="fname" value="<%= singleAdmin.fname %>"
                                        class="form-control">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" name="lname" value="<%= singleAdmin.lname %>"
                                        class="form-control">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Email Address</label>
                                    <input type="email" name="email" value="<%= singleAdmin.email %>"
                                        class="form-control">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">City</label>
                                    <select name="city" class="form-control">
                                        <option value="">--Select City--</option>
                                        <% var city=['surat','vapi','valsad','rajkot'] %>
                                            <% city.forEach((c)=> { %>
                                                <option value="<%= c %>" <% if(singleAdmin.city==c) { %> selected <% }
                                                        %>><%= c %>
                                                </option>
                                                <% }) %>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Gender</label><br>
                                    <div class="pt-2">
                                        <input type="radio" name="gender" value="male" <% if(singleAdmin.gender=='male'
                                            ) { %> checked <% } %>> Male &nbsp;&nbsp;
                                            <input type="radio" name="gender" value="female" <%
                                                if(singleAdmin.gender=='female' ) { %> checked <% } %>> Female
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Hobby</label><br>
                                    <input type="checkbox" name="hobby" value="reading" <%
                                        if(singleAdmin.hobby.includes('reading')) { %> checked <% } %>> Reading &nbsp;
                                        <input type="checkbox" name="hobby" value="coding" <%
                                            if(singleAdmin.hobby.includes('coding')) { %> checked <% } %>> Coding &nbsp;
                                            <input type="checkbox" name="hobby" value="music" <%
                                                if(singleAdmin.hobby.includes('music')) { %> checked <% } %>> Music
                                </div>

                                <div class="col-12 mt-4">
                                    <div class="d-flex align-items-center bg-light p-3 rounded-4">
                                        <img src="/<%= singleAdmin.profile_image %>" class="current-img-box me-3">
                                        <div>
                                            <label class="form-label mb-1">Change Profile Photo</label>
                                            <input type="file" name="profile_image"
                                                class="form-control form-control-sm">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">About Bio</label>
                                    <textarea name="about" class="form-control"
                                        rows="3"><%= singleAdmin.about %></textarea>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn-update-now">Update Administrator</button>
                                </div>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <a href="/admin/viewAdminPage" class="text-muted small fw-bold text-decoration-none">Cancel
                                and go back</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>