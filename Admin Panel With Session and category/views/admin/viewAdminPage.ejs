<%- include('../header') %>

    <style>
        .view-wrapper {
            padding: 30px;
            background: #edeff2;
            min-height: 90vh;
        }

        .table-card {
            background: white;
            border-radius: 30px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
            overflow: hidden;
        }

        .admin-table thead {
            background: #f8fafc;
        }

        .admin-table th {
            padding: 20px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            font-size: 0.75rem;
            border: none;
        }

        .admin-table td {
            padding: 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .profile-thumb {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            object-fit: cover;
        }

        .status-badge {
            padding: 6px 12px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            background: #f1f5f9;
            color: #64748b;
        }

        .action-btn {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            text-decoration: none;
        }

        .btn-edit {
            background: #f0f7ff;
            color: #007bff;
        }

        .btn-delete {
            background: #fff1f1;
            color: #ff4d4d;
        }

        .action-btn:hover {
            transform: translateY(-3px);
            filter: brightness(0.9);
        }
    </style>

    <div class="view-wrapper">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <h3 class="fw-bold m-0">System Administrators</h3>
            <a href="/admin/addAdminPage" class="btn btn-dark rounded-pill px-4 py-2 small">Add New Admin</a>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="table admin-table m-0">
                    <thead>
                        <tr>
                            <th>Admin</th>
                            <th>Contact info</th>
                            <th>Location</th>
                            <th>Gender</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allAdmin.forEach((data)=> { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="/<%= data.profile_image %>" class="profile-thumb me-3">
                                        <div>
                                            <div class="fw-bold text-dark">
                                                <%= data.fname %>
                                                    <%= data.lname %>
                                            </div>
                                            <div class="small text-muted">ID: #<%= data.id.toString().slice(-5) %>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small fw-600">
                                        <%= data.email %>
                                    </div>
                                    <div class="extra-small text-muted">
                                        <%= data.phone %>
                                    </div>
                                </td>
                                <td><span class="status-badge">
                                        <%= data.city %>
                                    </span></td>
                                <td><small class="text-capitalize text-muted">
                                        <%= data.gender %>
                                    </small></td>
                                <td class="text-end">
                                    <a href="/admin/editAdmin/<%= data.id %>" class="action-btn btn-edit me-2">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/admin/deleteAdmin?adminId=<%= data.id %>" class="action-btn btn-delete"
                                        onclick="return confirm('Remove this admin?')">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../footer') %>