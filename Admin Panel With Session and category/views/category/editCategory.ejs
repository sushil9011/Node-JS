<%- include('../header') %>

    <div class="form-wrapper" style="padding: 40px; background: #edeff2; min-height: 90vh;">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6">
                    <div class="glass-card" style="background: white; border-radius: 35px; padding: 40px;">
                        <h4 class="fw-bold mb-4">Edit Category</h4>

                        <form action="/category/updateCategory/<%= singleCategory.id %>" method="post"
                            enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="field-label" style="font-weight:700; color:#64748b;">Category Name</label>
                                <input type="text" name="category_name" value="<%= singleCategory.category_name %>"
                                    class="modern-input"
                                    style="border-radius: 15px; padding: 12px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;">
                            </div>

                            <div class="mb-4">
                                <label class="field-label" style="font-weight:700; color:#64748b;">Current Image</label>
                                <div class="mb-2">
                                    <img src="/<%= singleCategory.category_image %>" width="70"
                                        style="border-radius: 12px;">
                                </div>
                                <input type="file" name="category_image" class="modern-input"
                                    style="border-radius: 15px; padding: 12px; border: 1px solid #f1f5f9; background: #f8fafc; width: 100%;">
                            </div>

                            <button type="submit" class="btn-save"
                                style="background: #1a1b1e; color: white; border-radius: 18px; padding: 15px; width: 100%; border: none; font-weight: 700;">Update
                                Category</button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/category/viewCategory" class="text-muted small">Cancel Changes</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>