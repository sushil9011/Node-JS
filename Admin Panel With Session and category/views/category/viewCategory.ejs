<%- include('../header') %>

    <style>
        .cat-wrapper {
            padding: 30px;
            background: #edeff2;
            min-height: 90vh;
        }

        .cat-card {
            background: white;
            border-radius: 30px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
            overflow: hidden;
        }

        .cat-table th {
            padding: 20px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            font-size: 0.75rem;
            border: none;
            background: #f8fafc;
        }

        .cat-table td {
            padding: 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .cat-img-preview {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            object-fit: cover;
        }

        .action-btn {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: 0.2s;
        }

        .btn-edit {
            background: #f0f7ff;
            color: #007bff;
        }

        .btn-delete {
            background: #fff1f1;
            color: #ff4d4d;
        }

        .action-btn:hover {
            transform: translateY(-3px);
        }
    </style>

    <div class="cat-wrapper">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <h3 class="fw-bold m-0">Categories</h3>
            <a href="/category/addCategory" class="btn btn-dark rounded-pill px-4">Add Category</a>
        </div>

        <div class="cat-card">
            <div class="table-responsive">
                <table class="table cat-table m-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Preview</th>
                            <th>Category Name</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allCategories.forEach((data, index)=> { %>
                            <tr>
                                <td>
                                    <%= index + 1 %>
                                </td>
                                <td><img src="/<%= data.category_image %>" class="cat-img-preview"></td>
                                <td class="text-capitalize fw-bold text-dark">
                                    <%= data.category_name %>
                                </td>
                                <td class="text-end">
                                    <a href="/category/editCategory/<%= data.id %>" class="action-btn btn-edit me-2">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/category/deleteCategory?catId=<%= data.id %>"
                                        class="action-btn btn-delete" onclick="return confirm('Delete category?')">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../footer') %>