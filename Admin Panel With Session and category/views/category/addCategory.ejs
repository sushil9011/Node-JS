<%- include('../header') %>

    <style>
        .form-wrapper {
            padding: 40px;
            background: #edeff2;
            min-height: 90vh;
        }

        .glass-card {
            background: white;
            border-radius: 35px;
            padding: 40px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .field-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
            display: block;
        }

        .modern-input {
            border-radius: 15px;
            padding: 12px 20px;
            border: 1px solid #f1f5f9;
            background: #f8fafc;
            width: 100%;
            transition: 0.3s;
        }

        .modern-input:focus {
            background: white;
            border-color: #000;
            outline: none;
        }

        .btn-save {
            background: #1a1b1e;
            color: white;
            border-radius: 18px;
            padding: 15px;
            width: 100%;
            border: none;
            font-weight: 700;
            margin-top: 20px;
        }
    </style>

    <div class="form-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6">
                    <div class="glass-card">
                        <h4 class="fw-bold mb-4">New Category</h4>
                        <form action="/category/insertCategory" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="field-label">Category Name</label>
                                <input type="text" name="category_name" class="modern-input"
                                    placeholder="e.g. Electronics" required>
                            </div>
                            <div class="mb-4">
                                <label class="field-label">Category Image</label>
                                <input type="file" name="category_image" class="modern-input" required>
                            </div>
                            <button type="submit" class="btn-save shadow">Create Category</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>